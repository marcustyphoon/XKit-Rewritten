{
  "title": "Quote Replies",
  "description": "Reply to reply notifications",
  "icon": {
    "class_name": "ri-chat-quote-line",
    "color": "white",
    "background_color": "#00b8ff"
  },
  "help": "https://github.com/AprilSylph/XKit-Rewritten/wiki/Features#quote-replies",
  "preferences": {
    "mode": {
      "type": "select",
      "label": "Reply in:",
      "options": [
        { "value": "new post", "label": "A new post" },
        { "value": "reblog", "label": "A reblog of the source post" },
        { "value": "ask", "label": "Ask me every time" }
      ],
      "default": "new post"
    },
    "tagReplyingBlog": {
      "type": "checkbox",
      "label": "Automatically tag the quoted user",
      "default": false
    },
    "newTab": {
      "type": "checkbox",
      "label": "Open created posts in new tabs",
      "default": false
    }
  }
}
